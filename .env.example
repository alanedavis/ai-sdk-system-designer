# Copy this file to `.env` and fill in your key.
# `.env` is gitignored and loaded automatically by the npm scripts (--env-file).

# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# AssemblyAI API key — https://www.assemblyai.com/dashboard/api-keys
# Only needed for Step 0 (transcribing a recording with speaker labels via `npm run refine`).
# Anthropic has no speech-to-text model, so this stage brings its own provider.
ASSEMBLYAI_API_KEY=

# Optional: set to "production" to collapse rejected pitches to a header line.
# Defaults to development (full detail) when unset.
# NODE_ENV=production
